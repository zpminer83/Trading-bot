# Set to `staging` for Somnia Shannon testnet (chain ID 50312).
DREAMDEX_ENV=staging
DREAMDEX_CHAIN_ID=50312
DREAMDEX_SYMBOL=SOMI:USDso
DREAMDEX_PRIVATE_KEY=0xyour_private_key
# The current docs do not publish a single canonical Shannon RPC URL in Quick Start,
# so set this to your working Somnia Shannon endpoint before running.
DREAMDEX_RPC_URL=https://your-somnia-shannon-rpc
DREAMDEX_BASE_URL=https://stg.api.dreamdex.io
DREAMDEX_WS_URL=wss://stg.api.dreamdex.io/v0/ws/public
DREAMDEX_STRATEGY=grid
DREAMDEX_EXECUTION_MODE=contract
DREAMDEX_SIWE_DOMAIN=dreamdex.somnia.host
DREAMDEX_SIWE_URI=https://dreamdex.somnia.host
DREAMDEX_ORDER_AMOUNT=1
DREAMDEX_ALLOWED_SIDE=both
DREAMDEX_FUNDING_SOURCE=wallet
# Set to true to auto-deposit wallet funds into the vault at startup and withdraw on clean shutdown.
# Enables resting limit orders (normalOrder, postOnly) without manual vault management.
# When enabled, DREAMDEX_FUNDING_SOURCE is overridden to vault automatically.
# DREAMDEX_AUTO_VAULT=false
# Amount of native SOMI to keep in wallet as gas reserve when auto-depositing (only applies to native SOMI markets).
# DREAMDEX_VAULT_GAS_RESERVE=0.02
DREAMDEX_ORDER_TYPE=immediateOrCancel
DREAMDEX_SELF_MATCHING_OPTION=cancelTaker
DREAMDEX_EXPIRE_SECONDS=0
DREAMDEX_COOLDOWN_MS=20000
DREAMDEX_DRY_RUN=true
DREAMDEX_PERSISTENCE_DIR=./data

# Grid defaults — tuned for volume over per-trade margin.
DREAMDEX_GRID_TRADE_SIZE_QUOTE=20
DREAMDEX_GRID_STEP_BPS=8
DREAMDEX_GRID_MAX_SPREAD_BPS=25
DREAMDEX_GRID_MAX_LONG_QUOTE=60
# Stop trading if total portfolio value drops more than this from session start (0 = disabled).
DREAMDEX_GRID_MAX_SESSION_LOSS_QUOTE=5
# Cut a stuck long and re-anchor if sell trigger hasn't been met within this many ms (default 20min, 0 = disabled).
DREAMDEX_GRID_STUCK_TIMEOUT_MS=1200000

# Micro market-maker defaults for a small USDso wallet.
DREAMDEX_MM_STARTING_QUOTE_BALANCE_QUOTE=50
DREAMDEX_MM_STARTING_BASE_BALANCE=0
DREAMDEX_MM_QUOTE_SIZE_QUOTE=3
DREAMDEX_MM_TARGET_BASE_INVENTORY_QUOTE=8
DREAMDEX_MM_MAX_BASE_INVENTORY_QUOTE=15
DREAMDEX_MM_MIN_SPREAD_BPS=5
DREAMDEX_MM_TARGET_HALF_SPREAD_BPS=35
DREAMDEX_MM_INVENTORY_SKEW_BPS=20
DREAMDEX_MM_MAX_SESSION_LOSS_QUOTE=3

# Only needed when DREAMDEX_STRATEGY=threshold.
# DREAMDEX_BUY_BELOW_PRICE=0
# DREAMDEX_SELL_ABOVE_PRICE=999999

# Optional one-shot contract test overrides used by `npm run test:buy` and `npm run test:sell`.
# If DREAMDEX_TEST_PRICE is unset, the scripts use best ask for buys and best bid for sells.
# DREAMDEX_TEST_SYMBOL defaults to DREAMDEX_SYMBOL.
# DREAMDEX_TEST_AMOUNT defaults to DREAMDEX_ORDER_AMOUNT.
# DREAMDEX_TEST_SYMBOL=SOMI:USDso
# DREAMDEX_TEST_AMOUNT=1
# DREAMDEX_TEST_PRICE=0.1709
# DREAMDEX_TEST_SLIPPAGE_BPS=25
# DREAMDEX_TEST_AUTO_WITHDRAW=true

# ============================================================================
#  DreamTend — Environment Configuration
#  COPY THIS FILE TO .env AND FILL IN YOUR VALUES.
#  .env IS GITIGNORED — NEVER COMMIT IT.
# ============================================================================

# ----------------------------------------------------------------------------
#  NETWORK SELECTION
# ----------------------------------------------------------------------------
# Which network the bot trades on. Values: mainnet | testnet
# Mainnet = real money, real volume counts. Testnet = practice only.
NETWORK=testnet

# ----------------------------------------------------------------------------
#  WALLET (KEEP PRIVATE!)
# ----------------------------------------------------------------------------
# Private key (0x-prefixed) of the TRADING wallet. Funded by Somnia team.
# Wallet address: 0x8f0A24AE910D4B89C4422b6884d71739DBC1ec86
# WARNING: This key controls $50 USDso + 10 SOMI. Never share, never commit.
PRIVATE_KEY=

# Public address derived from PRIVATE_KEY (sanity-check field — bot will
# verify the derived address matches this value at startup).
WALLET_ADDRESS=0x8f0A24AE910D4B89C4422b6884d71739DBC1ec86

# ----------------------------------------------------------------------------
#  RPC ENDPOINTS
# ----------------------------------------------------------------------------
# Somnia mainnet (chainId 5031)
MAINNET_RPC=https://api.infra.mainnet.somnia.network

# Somnia testnet / Shannon (chainId 50312)
TESTNET_RPC=https://dream-rpc.somnia.network

# ----------------------------------------------------------------------------
#  DREAMDEX API
# ----------------------------------------------------------------------------
MAINNET_REST_API=https://api.dreamdex.io/v0
MAINNET_WS=wss://api.dreamdex.io/v0/ws/public

TESTNET_REST_API=https://stg.api.dreamdex.io/v0
TESTNET_WS=wss://stg.api.dreamdex.io/v0/ws/public

# ----------------------------------------------------------------------------
#  TRADING PARAMETERS
# ----------------------------------------------------------------------------
# Primary pair for market-making (use 'TOKEN:USDso' format).
PRIMARY_PAIR=USDC.e:USDso

# Secondary pair (lower allocation).
SECONDARY_PAIR=SOMI:USDso

# Capital allocation (fractions, must sum to ~1.0). See SKILL.md §11.
ALLOC_PRIMARY_MM=0.70
ALLOC_SECONDARY_MM=0.20
ALLOC_MOMENTUM=0.05
ALLOC_REBALANCER=0.05

# Spread defaults (basis points = 1/100 of 1%).
PRIMARY_SPREAD_BPS=1
SECONDARY_SPREAD_BPS=10

# Order size per leg (in quote-token, USDso) — bot derives base qty from price.
ORDER_NOTIONAL_USDSO=5

# Max simultaneous orders per side per pool (safety cap).
MAX_OPEN_ORDERS_PER_SIDE=2

# Quote refresh: re-quote when mid moves more than this in bps.
REQUOTE_TRIGGER_BPS=2

# ----------------------------------------------------------------------------
#  RISK CONTROLS
# ----------------------------------------------------------------------------
# Hard stop: if total wallet USDso value drops below this, halt all strategies.
RISK_HARD_FLOOR_USDSO=35

# Per-tx cap (sanity check — refuse any order with notional above this).
MAX_TX_NOTIONAL_USDSO=20

# ----------------------------------------------------------------------------
#  DAY-7 LIQUIDATION
# ----------------------------------------------------------------------------
# When to fire Day-7 liquidator (ISO timestamp, UTC).
# Snapshot is 2026-06-01 ~10:00 UTC; fire 2h before.
DAY7_LIQUIDATE_AT=2026-06-01T08:00:00Z

# ----------------------------------------------------------------------------
#  LLM (Ollama local)
# ----------------------------------------------------------------------------
OLLAMA_ENABLED=false
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
LLM_DECISION_INTERVAL_MIN=15

# ----------------------------------------------------------------------------
#  LOGGING
# ----------------------------------------------------------------------------
# Levels: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Where to write the CSV trade log (relative to repo root).
CSV_TRADE_LOG=data/trades.csv

# ----------------------------------------------------------------------------
#  FEATURE FLAGS
# ----------------------------------------------------------------------------
ENABLE_PRIMARY_MM=true
ENABLE_SECONDARY_MM=false
ENABLE_MOMENTUM=false
ENABLE_REBALANCER=false
ENABLE_DAY7_LIQUIDATOR=true
ENABLE_AGENT_KIT_REGISTRATION=false

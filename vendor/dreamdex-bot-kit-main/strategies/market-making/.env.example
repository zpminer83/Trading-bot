# Copy to .env and fill in. Inherits PRIVATE_KEY / NETWORK from the repo root .env
# if you run from there; otherwise set them here too.
PRIVATE_KEY=0x...
NETWORK=testnet

# Safe by default: logs intended quotes without sending transactions.
# Set DRY_RUN=false to go live.
DRY_RUN=true

MM_SYMBOL=USDC.e:USDso
MM_HALF_SPREAD_BPS=5
MM_NOTIONAL_USDSO=20
MM_TARGET_INVENTORY_USDSO=0
MM_INVENTORY_SKEW_BPS=4
MM_REQUOTE_TRIGGER_BPS=3
MM_MAX_BOOK_SPREAD_BPS=50
MM_REQUOTE_COOLDOWN_MS=2000
MM_REFRESH_INTERVAL_MS=5000

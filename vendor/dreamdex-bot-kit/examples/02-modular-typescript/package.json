{
  "name": "dreamtend",
  "version": "0.1.0",
  "description": "Autonomous multi-strategy market-making agent for DreamDEX on Somnia",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "build:check": "tsc -p tsconfig.check.json",
    "typecheck": "tsc -p tsconfig.check.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts' 'docs/**/*.md'",
    "deposit-vault": "tsx scripts/deposit-vault.ts",
    "sanity-check": "tsx scripts/sanity-check.ts"
  },
  "keywords": [
    "dreamdex",
    "somnia",
    "market-making",
    "trading-bot",
    "defi",
    "agent",
    "ethers",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anon/dreamtend.git"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "node-fetch": "^3.3.2",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "somnia-agent-kit": "^3.0.11",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^9.15.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.6"
  }
}

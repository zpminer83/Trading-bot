# Copy to .env and fill in. NEVER commit .env and never share your private key with anyone.

# Private key of your FUNDED dev wallet (the one issued for the program). Local only!
DREAMDEX_PRIVATE_KEY=

# Somnia RPC (required). mainnet chainId 5031 / testnet 50312 — inferred from the REST URL below.
DREAMDEX_CHAIN_RPC=

# REST API. Empty = mainnet (https://api.dreamdex.io/v0).
# For TESTNET set: https://stg.api.dreamdex.io/v0
DREAMDEX_REST_URL=

# Not required: token/contract addresses come from /v0/markets; fills — from the on-chain OrderFilled event.
# (WS is optional, off by default)
DREAMDEX_WS_URL=

# 1 = simulation (mock, no real orders). Remove/set 0 for a live/testnet run.
DRY_RUN=0
